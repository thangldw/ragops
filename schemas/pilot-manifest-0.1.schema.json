{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thangldw.github.io/ragops/schemas/pilot-manifest-0.1.schema.json",
  "title": "RAGOps pilot manifest 0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "pilot_id", "label", "period_start", "period_end",
    "synthetic", "consent_status", "eligible_user_ids", "targets"
  ],
  "properties": {
    "schema_version": {"const": "ragops-pilot-manifest-0.1"},
    "pilot_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "label": {"type": "string", "minLength": 1, "maxLength": 120},
    "period_start": {"type": "string", "format": "date"},
    "period_end": {"type": "string", "format": "date"},
    "synthetic": {"type": "boolean"},
    "consent_status": {"enum": ["synthetic", "approved"]},
    "eligible_user_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{2,63}$"}
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_repeat_usage_rate", "min_task_success_uplift", "min_time_saved_rate"],
      "properties": {
        "min_repeat_usage_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "min_task_success_uplift": {"type": "number", "minimum": 0, "maximum": 1},
        "min_time_saved_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
