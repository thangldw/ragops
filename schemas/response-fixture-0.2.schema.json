{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ragops.dev/schemas/response-fixture-0.2.schema.json",
  "title": "RAGOps response fixture overlay 0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "extends", "overrides"],
  "properties": {
    "schema_version": {"const": "0.2"},
    "extends": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "answer": {"type": "string"},
          "citation_ids": {"type": "array", "items": {"type": "string"}},
          "latency_ms": {"type": "integer", "minimum": 0},
          "cost_usd": {"type": "number", "minimum": 0},
          "human_approved": {"type": "boolean"},
          "retrieved_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
